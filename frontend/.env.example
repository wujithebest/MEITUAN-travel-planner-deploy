# ============================================
# 前端环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改
# ============================================

# 后端 API 地址
# 开发模式：使用相对路径，通过 Vite 代理转发到后端
# 生产模式：使用完整URL，如 https://api.example.com
VITE_API_BASE_URL=http://localhost:8002

# ============================================
# API 路径配置（可选）
# ============================================
# 路线生成API路径
# 默认值: /api/route/generate
# 
# 注意：如果后端路由有重复前缀问题（main.py中已加prefix="/api"，route.py中又有/api前缀），
# 实际路径可能是 /api/api/route/generate，此时可设置此变量：
# VITE_API_ROUTE_PATH=/api/api/route/generate
#
# 如果不设置，系统会在404时自动尝试fallback路径
VITE_API_ROUTE_PATH=/api/route/generate

# 是否使用Mock数据（开发测试用）
# true: 使用本地Mock数据，不调用后端API
# false: 调用真实后端API
VITE_USE_MOCK=false

# WebSocket 地址（暂不使用）
VITE_WS_URL=

# 高德地图 API Key（必填）
# 申请地址：https://lbs.amap.com/
VITE_GAODE_JSAPI_KEY=your_gaode_api_key_here

# 高德地图安全密钥（可选，如果启用了安全验证）
VITE_GAODE_SECURITY_CONFIG=your_gaode_security_config_here
