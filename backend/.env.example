# ============================================
# 旅游路线规划后端 - 环境变量配置
# ============================================

# 高德地图 API Key
GAODE_KEY=your_gaode_api_key

# LLM API 配置
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# 天气 API Key (和风天气)
WEATHER_KEY=your_weather_api_key

# 大众点评 Cookie (可选)
DIANPING_COOKIE=your_dianping_cookie

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# MongoDB 配置
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=travel_planner

# 服务端口 (Docker 模式使用 8000)
APP_PORT=8000

# JWT 密钥 (生产环境请修改为随机字符串)
SECRET_KEY=replace_with_strong_random_secret
